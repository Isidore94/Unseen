# UNSEEN — environment template. Copy to `.env` (which is gitignored) OR, better, set these
# as real environment variables on your machine. NEVER put real keys in a tracked file.

# PixelLab API token — used by the `pixellab` MCP server in .mcp.json (PHASE_8_MONETIZATION.md §7.10).
# Get it from your PixelLab account. Use a freshly ROTATED key if a previous one was ever exposed.
PIXELLAB_API_TOKEN=your_pixellab_api_token_here
